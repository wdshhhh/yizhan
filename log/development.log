9:              height: 300px;
10:              margin: 20px 0;
11:              padding: 15px;
12:              border: 1px solid #eee;
13:              border-radius: 8px;
14:          }
15:      </style>
16:    
17:      <!-- 修复：汇总柱状图（确保数据格式正确+颜色统一） -->
18:      <div class="summary-bar-chart">
19:        <canvas id="summaryBarChart"></canvas>
20:      </div>
21:    
22:      <%
23:        # 提前预处理数据，避免前端解析错误
24:        bar_labels = @abstract_models.map { |m| m.config.label_plural.gsub('"', '\\"') }
25:        bar_counts = @abstract_models.map { |m| @count[m.model.name].to_i }
26:        total_counts = bar_counts.sum
27:      %>
28:    
29:      <script>
30:          // 等待Chart.js完全加载+DOM就绪
31:          window.addEventListener('load', function() {
32:              try {
33:                  const ctx = document.getElementById('summaryBarChart').getContext('2d');
34:                  // 直接使用后端预处理的正确格式数据
35:                  const labels = <%= bar_labels.to_json %>;
36:                  const counts = <%= bar_counts.to_json %>;
37:                  const total = <%= total_counts.to_i %>;
38:    
39:                  // 统一颜色逻辑（与环形图/进度条完全一致，基于get_indicator规则）
40:                  const getBarColor = (percent) => {
41:                      if (percent >= 60) return '#28a745'; // success
42:                      if (percent >= 30) return '#ffc107'; // warning
43:                      return '#dc3545'; // danger
44:                  };
45:    
46:                  new Chart(ctx, {
47:                      type: 'bar',
48:                      data: {
49:                          labels: labels,
50:                          datasets: [{
51:                              label: '记录数量',
52:                              data: counts,
53:                              backgroundColor: counts.map(count => {
54:                                  const percent = total > 0 ? (count / total) * 100 : 0;
55:                                  return getBarColor(percent);
56:                              }),
57:                              borderWidth: 0,
58:                              borderRadius: 4,
59:                              barPercentage: 0.6
60:                          }]
61:                      },
62:                      options: {
63:                          responsive: true,
64:                          maintainAspectRatio: false,
65:                          plugins: {
66:                              legend: { display: false },
67:                              title: { display: true, text: '所有模型记录数量对比', font: { size: 16, weight: '500' }, padding: { bottom: 20 } },
68:                              tooltip: {
69:                                  backgroundColor: 'rgba(0,0,0,0.7)',
70:                                  padding: 10,
71:                                  borderRadius: 6,
72:                                  callbacks: {
73:                                      label: (context) => {
74:                                          const count = context.raw;
75:                                          const percent = total > 0 ? ((count / total) * 100).toFixed(1) : 0;
76:                                          return `数量: ${count} (${percent}%)`;
77:                                      }
78:                                  }
79:                              }
80:                          },
81:                          scales: {
82:                              y: { beginAtZero: true, grid: { color: '#f1f1f1' }, ticks: { precision: 0 } },
83:                              x: { grid: { display: false } }
84:                          },
85:                          animation: { duration: 1000, easing: 'easeOutQuart' }
86:                      }
87:                  });
88:              } catch (e) {
89:                  console.error('柱状图加载失败：', e);
90:              }
91:          });
92:      </script>
93:    
94:      <!-- 表格：修复环形图颜色与进度条一致 -->
95:      <table class="table table-condensed table-striped table-hover">
96:        <thead>
97:        <tr>
98:          <<th class="shrink model-name"><%= t "admin.table_headers.model_name" %></</th>
99:          <<th class="shrink last-created"><%= t "admin.table_headers.last_created" %></</th>
100:          <<th class="records" style="width: 250px;"><%= t "admin.table_headers.records" %></</th>
101:          <<th class="shrink controls"></</th>
102:        </tr>
  
